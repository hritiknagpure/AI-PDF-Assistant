# --- OpenAI (GPT) configuration -------------------------------------------
# Copy this file to ".env" and add your key, then restart `npm run dev`.
#
# NOTE: Vite exposes every VITE_* variable in the browser bundle. This is fine
# for local use; just don't publish a deployed site with your real key in it.

# Your OpenAI API key (https://platform.openai.com/api-keys)
VITE_OPENAI_API_KEY=sk-your-key-here

# Optional: which model to use (defaults to gpt-4o-mini)
# VITE_OPENAI_MODEL=gpt-4o-mini
